{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": [
    "typescript",
    "unicorn",
    "react",
    "react-perf",
    "import",
    "jsx-a11y",
    "node",
    "promise",
    "vitest",
    "vue"
  ],
  "ignorePatterns": [
    "**/dist",
    "**/build",
    "**/out",
    "**/.next",
    "**/.open-next",
    "**/.nuxt",
    "**/.output",
    "**/.svelte-kit",
    "**/.vitepress/cache",
    "**/.vitepress/dist",
    "**/.turbo",
    "**/.vercel",
    "**/.netlify",
    "**/.docusaurus",
    "**/.cache",
    "**/.parcel-cache",
    "**/.vite",
    "**/.astro",
    "**/.github",
    "**/_astro",
    "**/public",
    "**/public/build",
    "**/storybook-static",
    "*.min.*",
    "*.map",
    "**/_generated",
    "**/*.gen.*",
    "**/*.generated.*",
    "**/*.auto.*",
    "**/generated",
    "**/auto-generated",
    "**/codegen",
    "**/__generated__",
    "**/graphql-types.*",
    "**/schema.d.ts",
    "**/schema.graphql.d.ts",
    "**/*.d.ts.map",
    "**/coverage",
    "**/.nyc_output",
    "**/.expo",
    "**/.expo-shared",
    "**/android/build",
    "**/ios/build",
    "**/DerivedData/**/*",
    "**/bun.lock",
    "**/bun.lockb",
    "**/package-lock.json",
    "**/yarn.lock",
    "**/pnpm-lock.yaml",
    "**/next-env.d.ts",
    "**/worker-configuration.d.ts",
    "src/routeTree.gen.ts"
  ]
}
