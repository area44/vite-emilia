{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": [
    "typescript",
    "unicorn",
    "react",
    "react-perf",
    "import",
    "jsx-a11y",
    "node",
    "promise",
    "vitest"
  ],
  "ignorePatterns": [
    "*.min.*",
    "*.map",
    "**/public",
    "**/build",
    "**/dist",
    "**/out",
    "**/.output",
    "**/.github",
    "**/.next",
    "**/.astro",
    "**/.netlify"
  ]
}
