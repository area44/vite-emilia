{
  "name": "@area44/vite-emilia",
  "version": "26.04.22",
  "private": true,
  "description": "Minimalistic portfolio/photography site that features a masonry grid, page transitions, and large images",
  "author": "AREA44",
  "type": "module",
  "scripts": {
    "dev": "pnpm run generate:metadata && vite",
    "build": "pnpm run generate:metadata && vite build && pnpm run ssr:build && pnpm run prerender",
    "ssr:build": "vite build --ssr src/entry.server.tsx --outDir dist/server",
    "prerender": "node scripts/prerender.mjs",
    "format": "oxfmt",
    "lint": "oxlint",
    "generate:metadata": "node scripts/generate-image-metadata.mjs",
    "typecheck": "tsr generate && tsc"
  },
  "dependencies": {
    "@mdx-js/rollup": "^3.1.1",
    "@tailwindcss/vite": "^4.2.4",
    "@tanstack/react-router": "^1.168.23",
    "@tanstack/react-router-server": "^1.31.24",
    "@tanstack/router-plugin": "^1.167.23",
    "@vitejs/plugin-react": "^6.0.1",
    "blurhash": "^2.0.5",
    "isbot": "^5.1.39",
    "react": "^19.2.5",
    "react-blurhash": "^0.3.0",
    "react-dom": "^19.2.5",
    "remark-frontmatter": "^5.0.0",
    "remark-mdx-frontmatter": "^5.2.0",
    "tailwindcss": "^4.2.4",
    "vite": "^8.0.10"
  },
  "devDependencies": {
    "@tanstack/router-cli": "^1.166.34",
    "@tanstack/router-devtools": "^1.166.13",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "sharp": "^0.34.5",
    "typescript": "^6.0.3",
    "vite-imagetools": "^10.0.0"
  },
  "packageManager": "pnpm@10.33.2"
}
