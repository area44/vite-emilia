{
  "name": "@area44/vite-emilia",
  "version": "26.04.22",
  "private": true,
  "description": "Minimalistic portfolio/photography site that features a masonry grid, page transitions, and large images",
  "author": "AREA44",
  "type": "module",
  "scripts": {
    "generate:metadata": "node scripts/generate-image-metadata.mjs",
    "optimize:images": "node scripts/optimize-images.mjs",
    "dev": "node --run generate:metadata && vp dev",
    "build": "node --run generate:metadata && vp build && node --run optimize:images",
    "check": "vp check --fix",
    "prepare": "vp config"
  },
  "dependencies": {
    "@mdx-js/rollup": "^3.1.1",
    "@tailwindcss/vite": "^4.3.1",
    "@tanstack/react-router": "^1.170.15",
    "@tanstack/react-start": "^1.168.25",
    "@vitejs/plugin-react": "^6.0.2",
    "blurhash": "^2.0.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "remark-frontmatter": "^5.0.0",
    "remark-mdx-frontmatter": "^5.2.0",
    "sharp": "^0.35.1",
    "tailwindcss": "^4.3.1"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "svgo": "^4.0.1",
    "typescript": "^6.0.3",
    "vite": "npm:@voidzero-dev/vite-plus-core@^0.1.24",
    "vite-plus": "^0.1.24",
    "vitest": "npm:@voidzero-dev/vite-plus-test@^0.1.24"
  },
  "packageManager": "pnpm@11.6.0"
}
