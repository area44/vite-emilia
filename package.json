{
  "name": "@area44/vite-emilia",
  "version": "26.04.22",
  "private": true,
  "description": "Minimalistic portfolio/photography site that features a masonry grid, page transitions, and large images",
  "author": "AREA44",
  "type": "module",
  "scripts": {
    "dev": "pnpm run generate:metadata && react-router dev",
    "build": "pnpm run generate:metadata && react-router build && rm -rf dist && mv build/client dist",
    "start": "react-router-serve dist",
    "preview": "react-router-serve dist",
    "format": "oxfmt",
    "lint": "oxlint",
    "generate:metadata": "node scripts/generate-image-metadata.mjs",
    "typecheck": "react-router typegen && tsc"
  },
  "dependencies": {
    "@mdx-js/rollup": "^3.1.1",
    "@react-router/node": "^7.14.2",
    "@react-router/serve": "^7.14.2",
    "@tailwindcss/vite": "^4.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "isbot": "^5.1.39",
    "react": "19",
    "react-blurhash": "^0.3.0",
    "react-dom": "19",
    "react-router": "^7.14.2",
    "remark-frontmatter": "^5.0.0",
    "remark-mdx-frontmatter": "^5.0.0",
    "tailwindcss": "^4.0.0",
    "vite": "^8.0.5"
  },
  "devDependencies": {
    "@react-router/dev": "^7.14.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "blurhash": "^2.0.5",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "serve": "^14.2.6",
    "sharp": "^0.34.5",
    "typescript": "^6.0.3",
    "vite-imagetools": "^10.0.0",
    "vite-tsconfig-paths": "^6.1.1"
  },
  "packageManager": "pnpm@10.30.3"
}
