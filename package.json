{
  "name": "@area44/vite-emilia",
  "version": "26.04.22",
  "private": true,
  "description": "Minimalistic portfolio/photography site that features a masonry grid, page transitions, and large images",
  "author": "AREA44",
  "type": "module",
  "scripts": {
    "generate:metadata": "node scripts/generate-image-metadata.mjs",
    "optimize:images": "node scripts/optimize-images.mjs",
    "dev": "node --run generate:metadata && vp dev",
    "build": "node --run generate:metadata && vp build && node --run optimize:images",
    "check": "vp check --fix",
    "prepare": "vp config"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.3",
    "@tanstack/react-router": "^1.170.18",
    "@tanstack/react-start": "^1.168.28",
    "@vitejs/plugin-react": "^6.0.3",
    "blurhash": "^2.0.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sharp": "^0.35.3",
    "tailwindcss": "^4.3.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.5",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "satteri": "^0.9.5",
    "svgo": "^4.0.2",
    "typescript": "^7.0.2",
    "vite": "npm:@voidzero-dev/vite-plus-core@^0.2.5",
    "vite-plugin-satteri": "^0.2.15",
    "vite-plus": "^0.2.5"
  },
  "packageManager": "pnpm@11.13.1"
}
