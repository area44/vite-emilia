{
  "name": "@area44/vite-emilia",
  "version": "26.04.22",
  "private": true,
  "description": "Minimalistic portfolio/photography site that features a masonry grid, page transitions, and large images",
  "author": "AREA44",
  "type": "module",
  "scripts": {
    "generate:metadata": "node scripts/generate-image-metadata.mjs",
    "prerender": "node scripts/prerender.mjs",
    "dev": "node --run generate:metadata && vite",
    "ssr:build": "vite build --ssr src/entry.server.tsx --outDir dist/server",
    "build": "node --run generate:metadata && vite build && node --run ssr:build && node --run prerender",
    "format": "oxfmt",
    "lint": "oxlint"
  },
  "dependencies": {
    "@mdx-js/rollup": "^3.1.1",
    "@tailwindcss/vite": "^4.2.4",
    "@tanstack/react-router": "^1.168.26",
    "@tanstack/router-plugin": "^1.167.29",
    "@vitejs/plugin-react": "^6.0.1",
    "blurhash": "^2.0.5",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "remark-frontmatter": "^5.0.0",
    "remark-mdx-frontmatter": "^5.2.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.4",
    "vite": "^8.0.10",
    "vite-imagetools": "^10.0.0"
  },
  "devDependencies": {
    "@area44/oxfmt-config": "^0.1.0",
    "@area44/oxlint-config": "^0.1.0",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "typescript": "^6.0.3"
  }
}
