{
  "name": "@area44/vite-emilia",
  "version": "26.04.22",
  "private": true,
  "description": "Minimalistic portfolio/photography site that features a masonry grid, page transitions, and large images",
  "author": "AREA44",
  "type": "module",
  "scripts": {
    "dev": "node scripts/generate-image-metadata.mjs && vite",
    "build": "node scripts/generate-image-metadata.mjs && vite build && vite build --ssr src/entry.server.tsx --outDir dist/server && node scripts/prerender.mjs",
    "ssr:build": "vite build --ssr src/entry.server.tsx --outDir dist/server",
    "format": "oxfmt",
    "lint": "oxlint",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@mdx-js/rollup": "^3.1.1",
    "@tailwindcss/vite": "^4.2.4",
    "@tanstack/react-router": "^1.168.23",
    "@tanstack/router-plugin": "^1.167.23",
    "@vitejs/plugin-react": "^6.0.1",
    "blurhash": "^2.0.5",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "remark-frontmatter": "^5.0.0",
    "remark-mdx-frontmatter": "^5.2.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.4",
    "vite": "^8.0.10",
    "vite-imagetools": "^10.0.0"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^29.0.2",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
